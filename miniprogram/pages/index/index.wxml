<view class="page">
  <view class="hero">
    <view>
      <text class="eyebrow">VAPOR NOTES</text>
      <text class="title">Vapor Notes</text>
      <text class="subtitle">临时待办快速记录，长期待办按项目沉淀。</text>
    </view>
    <view class="sync-pill">{{syncStatus}}</view>
  </view>

  <view class="mode-switch">
    <view class="mode-item {{mode === 'temporary' ? 'active' : ''}}" data-mode="temporary" bindtap="setMode">临时待办</view>
    <view class="mode-item {{mode === 'longterm' ? 'active' : ''}}" data-mode="longterm" bindtap="setMode">长期待办</view>
  </view>

  <view class="search-card">
    <input class="search-input" placeholder="搜索内容" value="{{searchText}}" bindinput="onSearchChange" />
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-label">临时</text>
      <text class="stat-value">{{temporaryCount}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">长期</text>
      <text class="stat-value">{{longtermCount}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">项目</text>
      <text class="stat-value">{{projectCount}}</text>
    </view>
  </view>

  <!-- 临时 -->
  <block wx:if="{{mode === 'temporary'}}">
    <view class="input-card">
      <input class="note-input" placeholder="快速记一条临时待办" value="{{temporaryInput}}" bindinput="onTemporaryInput" confirm-type="done" bindconfirm="addTemporary" />
      <button class="add-button" bindtap="addTemporary">新增</button>
    </view>

    <scroll-view class="note-list" scroll-y="true">
      <block wx:for="{{temporaryNotes}}" wx:key="_id">
        
        <!-- ⭐关键改动：绑定点击 + 完成态 class -->
        <view 
          class="note-card {{item.completed ? 'completed' : ''}}" 
          data-id="{{item._id}}" 
          bindtap="toggleComplete"
        >
          <view class="note-main">
            <text class="note-content">{{item.content}}</text>
            <text class="note-time">{{item.displayTime}}</text>
          </view>

          <!-- 删除按钮保留，但阻止冒泡 -->
          <button 
            class="delete-button" 
            data-id="{{item._id}}" 
            catchtap="deleteNote"
          >
            删除
          </button>
        </view>

      </block>
      <view wx:if="{{temporaryNotes.length === 0}}" class="empty-state">暂无临时待办。</view>
    </scroll-view>
  </block>

  <!-- 长期 -->
  <block wx:if="{{mode === 'longterm'}}">
    <view class="input-card">
      <input class="note-input" placeholder="新建项目" value="{{projectInput}}" bindinput="onProjectInput" confirm-type="done" bindconfirm="addProject" />
      <button class="add-button" bindtap="addProject">项目</button>
    </view>

    <scroll-view class="project-list" scroll-x="true">
      <block wx:for="{{projects}}" wx:key="_id">
        <view class="project-chip {{selectedProjectId === item._id ? 'active' : ''}}" data-id="{{item._id}}" bindtap="selectProject">{{item.name}}</view>
      </block>
    </scroll-view>

    <view class="input-card">
      <input class="note-input" placeholder="{{selectedProjectId ? '给当前项目新增备忘录' : '请先创建项目'}}" value="{{longtermInput}}" bindinput="onLongtermInput" confirm-type="done" bindconfirm="addLongterm" />
      <button class="add-button" bindtap="addLongterm">新增</button>
    </view>

    <scroll-view class="note-list" scroll-y="true">
      <block wx:for="{{longtermNotes}}" wx:key="_id">

        <!-- ⭐同样改这里 -->
        <view 
          class="note-card {{item.completed ? 'completed' : ''}}" 
          data-id="{{item._id}}" 
          bindtap="toggleComplete"
        >
          <view class="note-main">
            <text class="note-content">{{item.content}}</text>
            <text class="note-time">{{item.displayTime}}</text>
          </view>

          <button 
            class="delete-button" 
            data-id="{{item._id}}" 
            catchtap="deleteNote"
          >
            删除
          </button>
        </view>

      </block>

      <view wx:if="{{projects.length === 0}}" class="empty-state">先创建一个长期项目。</view>
      <view wx:elif="{{longtermNotes.length === 0}}" class="empty-state">当前项目暂无内容。</view>
    </scroll-view>
  </block>
</view>