page {
  min-height: 100%;
  background: linear-gradient(145deg, #f5f5f7 0%, #e4e8f0 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.hero,
.search-card,
.input-card,
.stat-card,
.note-card {
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.68);
  box-shadow: 0 18rpx 52rpx rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(24rpx);
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
  border-radius: 36rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 8rpx;
  color: #6b7280;
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.sync-pill {
  flex-shrink: 0;
  align-self: flex-start;
  max-width: 220rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #4b5563;
  font-size: 22rpx;
  text-align: center;
}

.mode-switch {
  display: flex;
  gap: 12rpx;
  padding: 10rpx;
  margin-bottom: 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.56);
}

.mode-item {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #4b5563;
  font-size: 26rpx;
  text-align: center;
}

.mode-item.active {
  background: rgba(255, 255, 255, 0.94);
  color: #111827;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.search-card,
.input-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.search-input,
.note-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(248, 250, 252, 0.92);
  color: #1f2937;
  font-size: 28rpx;
}

.add-button {
  width: 136rpx;
  height: 76rpx;
  margin: 0;
  border-radius: 24rpx;
  background: rgba(31, 41, 55, 0.9);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 76rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  min-height: 116rpx;
  padding: 20rpx;
  border-radius: 28rpx;
}

.stat-card--tap {
  transition: opacity 0.1s;
}

.stat-card--tap.active {
  outline: 2rpx solid #1f2937;
}

.stat-label {
  display: block;
  color: #6b7280;
  font-size: 22rpx;
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.stat-card--projects {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.stat-card-top .stat-value {
  font-size: 40rpx;
}

.stat-card-sub {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(107, 114, 128, 0.2);
}

.stat-sub-label {
  color: #6b7280;
  font-size: 20rpx;
}

.stat-sub-value {
  font-size: 28rpx;
  font-weight: 700;
}

.project-list {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.project-chip-wrap {
  display: inline-flex;
  align-items: center;
  margin-right: 12rpx;
}

.project-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx 0 0 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #4b5563;
  font-size: 24rpx;
}

.project-chip.active {
  background: rgba(31, 41, 55, 0.9);
  color: #ffffff;
}

.project-chip-delete {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 64rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: rgba(239, 68, 68, 0.15);
  color: rgba(239, 68, 68, 0.8);
  font-size: 28rpx;
}

.note-list {
  min-height: 360rpx;
  max-height: 58vh;
}

.note-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.note-main {
  flex: 1;
  min-width: 0;
}

.note-content {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}

.note-time {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.delete-button {
  width: 108rpx;
  height: 58rpx;
  margin: 0;
  border-radius: 18rpx;
  background: rgba(239, 68, 68, 0.88);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 58rpx;
}

.empty-state {
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
  padding: 64rpx 0;
}
/* ===== 完成态 ===== */
.note-card.completed {
  opacity: 0.55;
}

.note-card.completed .note-content {
  text-decoration: line-through;
  color: #9ca3af;
}

.note-card.completed .note-time {
  color: #9ca3af;
}

.note-card.completed .delete-button {
  opacity: 0.6;
}
